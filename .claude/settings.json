{
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-html-page.js\"",
            "statusMessage": "Validating HTML page body"
          }
        ]
      }
    ]
  }
}
